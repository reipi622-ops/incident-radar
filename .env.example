# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://radar:radar@db:5432/incident_radar

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Geocoding ─────────────────────────────────────────────────────────────────
GEOCODING_PROVIDER=nominatim
NOMINATIM_USER_AGENT=incident-radar-mvp
GEOCODING_MIN_CONFIDENCE=0.5

# ── Deduplication ─────────────────────────────────────────────────────────────
DEDUP_TIME_WINDOW_HOURS=24
DEDUP_TEXT_SIMILARITY_THRESHOLD=0.65
DEDUP_LOCATION_RADIUS_KM=10.0
DEDUP_MIN_SCORE=0.6

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
